{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.vehicles_window_properties": {
            "initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"open": "query.property('simple_vehicles:window_toggle')=='open'"
						},
						{
							"opening": "query.property('simple_vehicles:window_toggle')=='opening'"
						},
						{
							"close": "query.property('simple_vehicles:window_toggle')=='close'"
						},
						{
							"closing": "query.property('simple_vehicles:window_toggle')=='closing'"
						}
					]
				},
				"open": {
					"animations":[
						"windows_open"
					],
					"transitions": [
						{
							"opening": "query.property('simple_vehicles:window_toggle')=='opening'"
						}
					]
				},
				"opening": {
					"animations":[

					],
					"transitions": [
						{
							"close": "query.property('simple_vehicles:window_toggle')=='close'"
						}
					]
				},
				"close": {
					"animations":[

					],
					"transitions": [
						{
							"closing": "query.all_animations_finished"
						}
					]
				},
				"closing": {
					"animations":[

					],
					"transitions": [
						{
							"open": "query.property('simple_vehicles:window_toggle')=='open'"
						}
					]
				}
			}
		}
	}
}